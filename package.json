{
  "name": "projetoguardedinheiro",
  "version": "1.0.0",
  "main": "main.js",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:backend": "cd backend && npm start",
    "dev:frontend": "cd frontend && npm start",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^38.1.0",
    "electron-builder": "^26.7.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.seuusuario.guardedinheiro",
    "productName": "GuardeDinheiro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "frontend/build/**/*",
      "backend/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}